ENVIRONMENT=development
# Local: sqlite. Cloud: paste Supabase pooler URI (postgresql://... is auto-normalized).
DATABASE_URL=sqlite:///./data/genomic_ast.db
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data/uploads
PUBLIC_API_BASE=http://localhost:8001
COMPUTE_BACKEND=local
# Cloud Run Jobs (when COMPUTE_BACKEND=cloud_run)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1
CLOUD_RUN_JOB_NAME=genomic-ast-worker
ENABLE_DEMO_FALLBACK=false
REQUIRE_REAL_TOOLS=true
TOOL_EXECUTION_MODE=real
ALLOW_FIXTURE_MODE=false
FIXTURE_DIR=./tests/fixtures/tools
RESFINDER_DB=/opt/dbs/resfinder_db
POINTFINDER_DB=/opt/dbs/pointfinder_db
AMRFINDER_DB=/opt/dbs/amrfinder/2026-05-15.1
TOOL_TIMEOUT_SECONDS=1800
AMRFINDER_THREADS=4
MAX_UPLOAD_BYTES=100000000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Supabase Storage (S3-compatible) — used when STORAGE_BACKEND=s3
S3_ENDPOINT_URL=
S3_BUCKET=genomic-ast
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
MODAL_APP_NAME=genomic-ast
# Required on Render when COMPUTE_BACKEND=modal
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
